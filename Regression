import pandas as pd
from sklearn.linear_model import LinearRegression
df = pd.read_csv('/Users/shreyaanand/Desktop/is 477/Merged_Data.csv')
df['arr_delay'] = pd.to_numeric(df['arr_delay'], errors='coerce')
df = df.dropna(subset=['RO', 'arr_delay'])
df_region = pd.get_dummies(df, columns=['RO'], drop_first=True)

X = df_region.filter(like='RO_')
y = df_region['arr_delay']

model1 = LinearRegression()
model1.fit(X, y)
coef_df = pd.DataFrame({
    'Region': X.columns,
    'Coefficient': model1.coef_
})

print(coef_df)
print("R^2:", model1.score(X, y))

